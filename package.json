{
  "name": "programatic-agent",
  "version": "0.1.0",
  "description": "TUI de execucao guiada com kanban: pipeline de prompts em multiplos worktrees",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "programatic-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "recommended-models.json",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx --watch src/cli.tsx",
    "start": "tsx src/cli.tsx",
    "build": "tsc && chmod +x dist/cli.js",
    "build:link": "npm run build && npm link",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inkjs/ui": "^1.0.0",
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "ink": "^4.4.1",
    "ink-kanban-board": "^1.1.9",
    "ink-select-input": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "model-selector-ink": "^2.0.0",
    "nanoid": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
