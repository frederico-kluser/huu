{
  "name": "huu",
  "version": "1.0.0",
  "description": "A multi-agent orchestrator for software development that thinks like a **showrunner**.",
  "main": "dist/src/cli/index.js",
  "bin": {
    "huu": "bin/huu"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json && cp -r src/db/migrations dist/src/db/migrations",
    "start": "node dist/src/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run test",
    "docs:api": "typedoc",
    "docs:api:check": "typedoc --logLevel Verbose"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:37167/git/frederico-kluser/huu"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "simple-git": "^3.32.3"
  }
}
